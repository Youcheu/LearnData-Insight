# Exemple de variables d'environnement pour LearnData Insight
# Ne commitez jamais votre vrai fichier .env dans le dépôt.
# En production Vercel, la base SQLite sera stockée temporairement dans /tmp.
# Pour une base externe, définissez DATABASE_URL.

PORT=3000
DATABASE_PATH=./database.sqlite
DATABASE_URL=
NODE_ENV=development
