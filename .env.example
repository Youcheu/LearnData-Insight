# Supabase environment variables for local development
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<your-public-anon-key>

# Optional: if you already have your Supabase database URL available,
# the build script can parse the project host from it.
# DATABASE_URL=postgresql://username:password@<host>:5432/postgres
